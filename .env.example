# ─────────────────────────────────────────────
# AI Grocery Planner — required environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# Firebase — get these from your Firebase project console
# Project Settings → Your apps → SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloud Run — the base URL of the deployed Cloud Run service
# Used by the Groq/Oracle proxy. Leave blank during local dev if not yet deployed.
VITE_CLOUD_RUN_URL=

# Google Translate API — used for multi-language meal plan output (Phase 7)
# Get from Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_TRANSLATE_API_KEY=
